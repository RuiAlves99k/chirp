root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled
# Allow PascalCase for @Composable and @Preview functions (Compose convention)
ktlint_function_naming_ignore_when_annotated_with = Composable,Preview

# KMP iOS entry points use PascalCase factory functions (e.g. MainViewController)
[{**/iosMain/**/*.kt,**/iosMain/**/*.kts}]
ktlint_standard_function-naming = disabled

